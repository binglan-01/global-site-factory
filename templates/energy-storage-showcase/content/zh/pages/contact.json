{
  "slug": "/contact",
  "template": "standard",
  "seo": {
    "title": "联系我们",
    "description": "通过标准 /api/lead 接口收集线索，主题内不配置 webhook。"
  },
  "sections": [
    {
      "type": "hero",
      "title": "联系储能壳体团队",
