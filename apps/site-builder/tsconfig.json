{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": "../..",
    "paths": {
      "@factory/validators": ["packages/validators/src/index.ts"],
      "@factory/seo": ["packages/seo/src/index.ts"],
      "@factory/theme-enterprise": ["packages/theme-enterprise/src/index.ts"],
      "@factory/theme-technical-product-showcase": [
        "packages/theme-technical-product-showcase/src/index.ts"
      ],
      "@factory/theme-energy-storage-showcase": [
        "packages/theme-energy-storage-showcase/src/index.ts"
      ],
      "@factory/ui": ["packages/ui/src/index.ts"]
    },
    "types": ["astro/client"]
  },
  "include": [".astro/types.d.ts", "src/**/*.ts", "src/**/*.tsx", "src/**/*.astro"]
}
