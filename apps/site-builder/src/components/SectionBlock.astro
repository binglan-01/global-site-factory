---
import {
  Gallery,
  Hero,
  type GallerySection,
  type HeroSection,
} from "@factory/theme-technical-product-showcase";
import {
  FeatureList as EnergyFeatureList,
  Hero as EnergyHero,
} from "@factory/theme-energy-storage-showcase";
import type { Section, SiteConfig } from "@factory/validators";
import type { FeatureListSection } from "@factory/theme-enterprise";
import { SectionRenderer } from "./SectionRenderer";

type Props = {
  section: Section;
  siteConfig: SiteConfig;
  siteSlug: string;
  pageUrl: string;
};

const { section, siteConfig, siteSlug, pageUrl } = Astro.props;

/* THIS IS TEMPLATE COUPLING POINT — must match SectionRenderer.tsx technical-product-showcase hero branch */
const isSplitCarouselHero =
  siteConfig.theme === "technical-product-showcase" &&
  section.type === "hero" &&
  section.variant === "split-carousel" &&
  Boolean(section.carousel?.images?.length);

const splitHero: HeroSection | null = isSplitCarouselHero ? (section as HeroSection) : null;

const isEssFullscreenCarousel =
  siteConfig.theme === "energy-storage-showcase" &&
  section.type === "hero" &&
  section.variant === "fullscreen-carousel" &&
  Boolean(section.carousel?.images?.length);

const essCarouselHero: HeroSection | null = isEssFullscreenCarousel ? (section as HeroSection) : null;

const isEssScrollMaskCarousel =
  siteConfig.theme === "energy-storage-showcase" &&
  section.type === "feature-list" &&
  section.variant === "scroll-mask-carousel";

const essScrollMaskSection: FeatureListSection | null = isEssScrollMaskCarousel
  ? (section as FeatureListSection)
  : null;

/* THIS IS TEMPLATE COUPLING POINT — hydrated gallery/lightbox belongs to technical-product-showcase only today */
const isHydratedTpsGallery =
  siteConfig.theme === "technical-product-showcase" &&
  section.type === "gallery" &&
  section.lightbox === true &&
  Boolean(section.images?.length);

const hydratedGallery: GallerySection | null = isHydratedTpsGallery ? (section as GallerySection) : null;
---

{
  splitHero ? (
    <Hero client:visible section={splitHero} />
  ) : essCarouselHero ? (
    <EnergyHero client:visible section={essCarouselHero} />
  ) : essScrollMaskSection ? (
    <EnergyFeatureList client:visible section={essScrollMaskSection} />
  ) : hydratedGallery ? (
    <Gallery client:visible section={hydratedGallery} />
  ) : (
    <SectionRenderer section={section} siteConfig={siteConfig} siteSlug={siteSlug} pageUrl={pageUrl} />
  )
}
