---
import { buildCanonical } from "@factory/seo";
import type { PageContent } from "@factory/validators";
import SectionBlock from "../../components/SectionBlock.astro";
import { pagesByLocale, siteConfig } from "../../generated";
import SiteLayout from "../../layouts/SiteLayout.astro";

export function getStaticPaths() {
  return siteConfig.locales
    .filter((locale) => locale !== siteConfig.defaultLocale)
    .map((locale) => {
      const page = pagesByLocale[locale]?.find((candidate) => candidate.slug === "/");

      if (!page) {
        throw new Error(`Missing localized homepage for locale "${locale}".`);
      }

      return {
        params: {
          locale,
        },
        props: {
          locale,
          page,
        },
      };
    });
}

type Props = {
  locale: string;
  page: PageContent;
};

const { locale, page } = Astro.props;
const pageUrl = buildCanonical(siteConfig.domain, locale, page.slug, siteConfig.defaultLocale);
---

<SiteLayout siteConfig={siteConfig} page={page} locale={locale}>
  {page.sections.map((section) => (
    <SectionBlock section={section} siteConfig={siteConfig} siteSlug={siteConfig.slug} pageUrl={pageUrl} />
  ))}
</SiteLayout>
