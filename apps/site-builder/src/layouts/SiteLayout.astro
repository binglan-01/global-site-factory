---
import { buildCanonical, buildOrganizationSchema, buildPageTitle } from "@factory/seo";
import "@factory/theme-enterprise/styles/theme-enterprise.css";
import "@factory/theme-technical-product-showcase/styles/theme-technical-product-showcase.css";
import "@factory/theme-energy-storage-showcase/styles/theme-energy-storage-showcase.css";
import { resolveLocalizedString, type LocalizedString, type PageContent, type SiteConfig } from "@factory/validators";
import type { FooterColumnResolved } from "@factory/theme-enterprise";
import { Header as EnterpriseHeader } from "@factory/theme-enterprise";
import { Header as TechnicalProductShowcaseHeader } from "@factory/theme-technical-product-showcase";
import { Header as EnergyStorageShowcaseHeader } from "@factory/theme-energy-storage-showcase";
import {
  getThemeBundle,
  type FooterLink,
  type HeaderNavItem,
} from "../themes/registry";
import { buildLanguageLinks } from "../utils/locale-switch";
import { buildLocalizedPath } from "../utils/route";

type Props = {
  siteConfig: SiteConfig;
  page: PageContent;
  locale: string;
};

const { siteConfig, page, locale } = Astro.props;
const trimmedPageTitle = page.seo.title?.trim() ?? "";
const resolvedSeoTitle =
  trimmedPageTitle.length > 0 ? trimmedPageTitle : siteConfig.seo.defaultTitle;
const title = buildPageTitle(resolvedSeoTitle, siteConfig.seo.titleTemplate);
const pageUrl = buildCanonical(siteConfig.domain, locale, page.slug, siteConfig.defaultLocale);
const organizationSchema = buildOrganizationSchema(siteConfig);

const navigation: HeaderNavItem[] = siteConfig.navigation.map((item) => ({
  label: resolveLocalizedString(item.label, locale, siteConfig.defaultLocale),
  href: buildLocalizedPath(siteConfig, locale, item.href),
}));

const footerPrivacyLabel = resolveLocalizedString(
  siteConfig.footerLinkLabels.privacy,
  locale,
  siteConfig.defaultLocale,
);
const footerTermsLabel = resolveLocalizedString(
  siteConfig.footerLinkLabels.terms,
  locale,
  siteConfig.defaultLocale,
);

const footerLinks: FooterLink[] = [
  {
    label: footerPrivacyLabel,
    href: buildLocalizedPath(siteConfig, locale, "/privacy"),
  },
  {
    label: footerTermsLabel,
    href: buildLocalizedPath(siteConfig, locale, "/terms"),
  },
  {
    label: siteConfig.legal.privacyEmail,
    href: `mailto:${siteConfig.legal.privacyEmail}`,
  },
];

const copyrightText = `© ${new Date().getFullYear()} ${siteConfig.company.legalName}`;
const homeHref = buildLocalizedPath(siteConfig, locale, "/");
const bodyClass = `theme-${siteConfig.theme}`;

const languageLinks = buildLanguageLinks(siteConfig, locale, page.slug);

const { Footer } = getThemeBundle(siteConfig.theme);

const footerColumnsResolved: FooterColumnResolved[] | undefined =
  siteConfig.footerColumns?.map((column) => ({
    title: resolveLocalizedString(column.title, locale, siteConfig.defaultLocale),
    links: column.links.map((link) => ({
      label: resolveLocalizedString(link.label, locale, siteConfig.defaultLocale),
      href: buildLocalizedPath(siteConfig, locale, link.href),
    })),
  })) ?? undefined;

const footerColumnsProp =
  footerColumnsResolved !== undefined && footerColumnsResolved.length > 0
    ? footerColumnsResolved
    : undefined;

const headerCompanyDisplay = resolveLocalizedString(
  siteConfig.company.displayName,
  locale,
  siteConfig.defaultLocale,
);

function localizeSiteHref(href: string): string {
  const hashIndex = href.indexOf("#");
  const rawPath = hashIndex >= 0 ? href.slice(0, hashIndex) : href;
  const hash = hashIndex >= 0 ? href.slice(hashIndex) : "";
  if (!rawPath.startsWith("/")) {
    return href;
  }

  const pathForBuilder = rawPath.length === 0 ? "/" : rawPath;

  return `${buildLocalizedPath(siteConfig, locale, pathForBuilder)}${hash}`;
}

const fabSrc = siteConfig.floatingActions;

function resolveFabLabel(value: LocalizedString | undefined): string | undefined {
  if (value === undefined) {
    return undefined;
  }
  return resolveLocalizedString(value, locale, siteConfig.defaultLocale);
}

const floatingActionsLocalized = fabSrc
  ? {
      enquiry: fabSrc.enquiry
        ? {
            enabled: fabSrc.enquiry.enabled,
            href: localizeSiteHref(fabSrc.enquiry.href),
            label: resolveFabLabel(fabSrc.enquiry.label),
            ariaLabel: resolveFabLabel(fabSrc.enquiry.ariaLabel),
          }
        : undefined,
      document: fabSrc.document
        ? {
            enabled: fabSrc.document.enabled,
            href: localizeSiteHref(fabSrc.document.href),
            label: resolveFabLabel(fabSrc.document.label),
            ariaLabel: resolveFabLabel(fabSrc.document.ariaLabel),
          }
        : undefined,
      support: fabSrc.support
        ? {
            enabled: fabSrc.support.enabled,
            href: localizeSiteHref(fabSrc.support.href),
            label: resolveFabLabel(fabSrc.support.label),
            ariaLabel: resolveFabLabel(fabSrc.support.ariaLabel),
          }
        : undefined,
      backToTop: fabSrc.backToTop
        ? {
            enabled: fabSrc.backToTop.enabled,
            label: resolveFabLabel(fabSrc.backToTop.label),
            ariaLabel: resolveFabLabel(fabSrc.backToTop.ariaLabel),
          }
        : undefined,
    }
  : undefined;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={page.seo.description} />
    <link rel="canonical" href={pageUrl} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
  </head>
  <body class={bodyClass}>
    {
      siteConfig.theme === "energy-storage-showcase" ? (
        <EnergyStorageShowcaseHeader
          client:load
          companyName={headerCompanyDisplay}
          homeHref={homeHref}
          navigation={navigation}
          languageLinks={languageLinks}
        />
      ) : siteConfig.theme === "technical-product-showcase" ? (
        <TechnicalProductShowcaseHeader
          companyName={headerCompanyDisplay}
          homeHref={homeHref}
          navigation={navigation}
          languageLinks={languageLinks}
        />
      ) : (
        <EnterpriseHeader
          companyName={headerCompanyDisplay}
          homeHref={homeHref}
          navigation={navigation}
          languageLinks={languageLinks}
        />
      )
    }
    <main>
      <slot />
    </main>
    <Footer
      companyName={siteConfig.company.legalName}
      copyrightText={copyrightText}
      links={footerLinks}
      footerColumns={footerColumnsProp}
      floatingActions={floatingActionsLocalized}
    />
  </body>
</html>
